# Set this to your backend API URL
# For testing on a real device or emulator, use your PC's LAN IP:
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.3:5000/api/v1
#
# To find your LAN IP:
#   Windows: ipconfig → look for "IPv4 Address" under your Wi-Fi/Ethernet adapter
#   Mac/Linux: ifconfig or ip addr

